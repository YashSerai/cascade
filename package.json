{
  "name": "cascade",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"tsx watch server/index.ts\" \"vite\"",
    "build": "vite build && tsup",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
